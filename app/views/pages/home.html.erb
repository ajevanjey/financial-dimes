<div class="home-wrapper">

  <%# ---------- AMBIENT DATA STREAM (right-side background) ---------- %>
  <%
    col_a = [
      ["AAPL",  "+1.24", :up],   ["NVDA",  "+3.18", :up],   ["TSLA",  "-0.92", :down],
      ["MSFT",  "+0.55", :up],   ["GOOGL", "+0.81", :up],   ["AMZN",  "-0.14", :down],
      ["META",  "+1.85", :up],   ["AMD",   "+2.04", :up],   ["NFLX",  "-1.10", :down],
      ["DIS",   "+0.42", :up],   ["JPM",   "+0.31", :up],   ["BAC",   "+0.18", :up],
      ["V",     "+0.92", :up],   ["MA",    "+0.78", :up],   ["KO",    "-0.22", :down],
      ["PEP",   "+0.45", :up],   ["MCD",   "-0.08", :down], ["NKE",   "-0.50", :down],
      ["COST",  "+0.81", :up],   ["WMT",   "+0.35", :up]
    ]
    col_b = [
      ["S&P",   "+0.84", :up],   ["NDX",   "+1.12", :up],   ["DJI",   "-0.21", :down],
      ["BTC",   "+2.47", :up],   ["ETH",   "+1.85", :up],   ["GLD",   "-0.55", :down],
      ["TLT",   "+0.04", :up],   ["VIX",   "-3.20", :down], ["XOM",   "+0.92", :up],
      ["CVX",   "+1.04", :up],   ["BA",    "-1.40", :down], ["F",     "+0.65", :up],
      ["GM",    "-0.10", :down], ["UBER",  "+1.95", :up],   ["ABNB",  "+0.74", :up],
      ["SHOP",  "-0.85", :down], ["SQ",    "+1.30", :up],   ["PYPL",  "-0.42", :down],
      ["BABA",  "+2.10", :up],   ["AVGO",  "+1.55", :up]
    ]
  %>
  <div class="fd-stream" aria-hidden="true">
    <span class="fd-stream-caveat">// sample data — for illustration</span>
    <div class="fd-stream-col fd-stream-col-a">
      <% (col_a * 2).each do |tkr, pct, dir| %>
        <div class="fd-stream-item">
          <span class="fd-stream-tkr"><%= tkr %></span>
          <span class="fd-stream-pct fd-stream-<%= dir %>"><%= pct %>%</span>
        </div>
      <% end %>
    </div>
    <div class="fd-stream-col fd-stream-col-b">
      <% (col_b * 2).each do |tkr, pct, dir| %>
        <div class="fd-stream-item">
          <span class="fd-stream-tkr"><%= tkr %></span>
          <span class="fd-stream-pct fd-stream-<%= dir %>"><%= pct %>%</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# ---------- HERO ---------- %>
  <section class="fd-hero">
    <div class="container">
      <div class="row align-items-center g-5 fd-hero-row">
        <div class="col-lg-7 fd-hero-copy">
          <div class="fd-hero-eyebrow">
            <span class="fd-pulse"></span>
            Free &middot; Non-profit &middot; For everyone
          </div>

          <h1 class="fd-hero-title">
            Stock research,<br>
            <span class="fd-accent">made for everyone.</span>
          </h1>

          <p class="fd-hero-subtitle">
            Build a watchlist by chatting. Get sourced answers on every ticker
            you save. Then every Sunday night, a custom report on what's moving
            lands in your inbox — pulled only from the names you actually care
            about. Free, non-profit, no ads.
          </p>

          <div class="fd-hero-ctas">
            <% if user_signed_in? %>
              <%= button_to "Start a new chat", chats_path, method: :post, class: "fd-btn fd-btn-primary", form: { class: "fd-btn-form" } %>
            <% else %>
              <%= link_to "Start chatting — free", new_user_registration_path, class: "fd-btn fd-btn-primary" %>
            <% end %>
          </div>
        </div>

        <div class="col-lg-5 fd-hero-device-col">
          <%# Standalone green glow sitting strictly behind the phone %>
          <div class="fd-iphone-glow" aria-hidden="true"></div>

          <%# Floating iPhone with the chat mockup inside %>
          <div class="fd-iphone">
            <div class="fd-iphone-frame">
              <div class="fd-iphone-island"></div>
              <div class="fd-iphone-screen">

                <%# ---- chat mockup (lives inside the phone) ---- %>
                <div class="fd-chat-mockup">
        <div class="fd-chat-header">
          <span class="fd-chat-avatar">
            <%= render "shared/brand_mark" %>
          </span>
          <div class="fd-chat-header-text">
            <div class="fd-chat-name">Financial Dimes</div>
            <div class="fd-chat-status">online &middot; pulling from public sources</div>
          </div>
        </div>

        <div class="fd-chat-body">
          <div class="fd-chat-msg fd-chat-msg-bot">
            <div class="fd-chat-bubble">
              Hey 👋 Tell me a ticker to watch, or ask about one I'm already tracking.
            </div>
          </div>

          <div class="fd-chat-msg fd-chat-msg-user">
            <div class="fd-chat-bubble">add NVDA and TSLA to my list</div>
          </div>

          <div class="fd-chat-msg fd-chat-msg-bot">
            <div class="fd-chat-bubble">
              Done. <span class="fd-chat-tkr">NVDA</span> and <span class="fd-chat-tkr">TSLA</span> are on your watchlist. Want a quick read on either?
            </div>
          </div>

          <div class="fd-chat-msg fd-chat-msg-user">
            <div class="fd-chat-bubble">yeah, what's the vibe on NVDA?</div>
          </div>

          <div class="fd-chat-msg fd-chat-msg-bot">
            <div class="fd-chat-snapshot">
              <div class="fd-chat-snapshot-head">
                <span class="fd-chat-tkr-lg">NVDA</span>
                <span class="fd-chat-sentiment fd-chat-sentiment-bull">▲ Bullish</span>
              </div>
              <ul class="fd-chat-bullets">
                <li>Earnings beat expectations on data-center revenue.</li>
                <li>Analyst upgrades outpacing downgrades 4-to-1 this week.</li>
                <li>One risk flagged: export controls into Asia.</li>
              </ul>
              <div class="fd-chat-sources">
                <span class="fd-chat-sources-label">sources</span>
                <a class="fd-chat-source-chip" href="#">Reuters</a>
                <a class="fd-chat-source-chip" href="#">SEC filing</a>
                <a class="fd-chat-source-chip" href="#">CNBC</a>
              </div>
            </div>
          </div>
        </div>

        <div class="fd-chat-input">
          <input type="text" placeholder="Ask anything, or add a ticker…" disabled>
          <button type="button" class="fd-chat-send" aria-label="Send">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2" fill="currentColor"/>
            </svg>
          </button>
        </div>
                </div>
                <%# ---- end chat mockup ---- %>

              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ---------- HOW IT WORKS ---------- %>
  <section class="fd-section">
    <div class="container">
      <div class="fd-section-head">
        <span class="fd-kicker">How it works</span>
        <h2 class="fd-section-title">Ask. Learn. Save.</h2>
      </div>

      <div class="row g-4 fd-steps">
        <div class="col-md-4">
          <div class="fd-step-card">
            <div class="fd-step-num">01 &middot; Chat</div>
            <h3>Build your list by talking</h3>
            <p>"Add NVDA." "Drop TSLA." "What's on my list?" Add and remove tickers in plain English — your watchlist updates as you chat.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="fd-step-card">
            <div class="fd-step-num">02 &middot; Read</div>
            <h3>Get the sentiment, sourced</h3>
            <p>Ask about any ticker on your list and get a summary — sentiment, headlines, and the why. Every claim links to its public source so you can dig deeper.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="fd-step-card">
            <div class="fd-step-num">03 &middot; Sunday</div>
            <h3>Your weekly snapshot</h3>
            <p>Every Sunday night, a custom report on your tickers lands in your inbox. Sentiment, key moves, headlines — built only from the names you're actually watching.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ---------- WHY WE BUILT THIS ---------- %>
  <section class="fd-section fd-section-alt">
    <div class="container">
      <div class="fd-section-head">
        <span class="fd-kicker">Why this exists</span>
        <h2 class="fd-section-title">Built for everyone. Owned by no one.</h2>
      </div>

      <div class="row g-4">
        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# Free — price tag with zero %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17 4H6a2 2 0 0 0-2 2v11l11 11a2 2 0 0 0 2.83 0l8.17-8.17a2 2 0 0 0 0-2.83L17 4z"/>
                <circle cx="10.5" cy="10.5" r="1.5" fill="currentColor"/>
                <text x="16" y="22" font-family="Poppins, sans-serif" font-size="9" font-weight="700" fill="currentColor" stroke="none" text-anchor="middle">$0</text>
              </svg>
            </div>
            <h4>Free forever</h4>
            <p>No credit card. No trial. No "premium" tier hiding the good stuff. Free now, free later.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# Non-profit — two interlocked circles (community) %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="16" r="7"/>
                <circle cx="21" cy="16" r="7"/>
              </svg>
            </div>
            <h4>Non-profit project</h4>
            <p>No investors to please, no shareholders demanding growth. We're not selling you to anyone.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# No ads — banner with diagonal slash %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="5" y="10" width="22" height="12" rx="1.5"/>
                <line x1="5" y1="5" x2="27" y2="27"/>
              </svg>
            </div>
            <h4>No ads, ever</h4>
            <p>You won't see banner ads, sponsored tickers, or "promoted" content. The page you see is the page everyone sees.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# Public sources — broadcast / RSS arcs %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="23" r="2" fill="currentColor" stroke="none"/>
                <path d="M5 17a10 10 0 0 1 10 10"/>
                <path d="M5 11a16 16 0 0 1 16 16"/>
                <path d="M5 5a22 22 0 0 1 22 22"/>
              </svg>
            </div>
            <h4>Public sources only</h4>
            <p>Financial Dimes pulls from RSS feeds and free public APIs — the same data anyone can access, just stitched together for you.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# Chat — speech bubble with three dots %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M27 18a3 3 0 0 1-3 3H12l-5 5V8a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v10z"/>
                <circle cx="12" cy="13" r="1" fill="currentColor" stroke="none"/>
                <circle cx="17" cy="13" r="1" fill="currentColor" stroke="none"/>
                <circle cx="22" cy="13" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <h4>Conversational by design</h4>
            <p>You don't need to know finance jargon. Ask in your own words; get answers in your own words.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="fd-feature">
            <div class="fd-feature-icon">
              <%# Built in the open — code brackets %>
              <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="11 9 5 16 11 23"/>
                <polyline points="21 9 27 16 21 23"/>
                <line x1="18" y1="7" x2="14" y2="25"/>
              </svg>
            </div>
            <h4>Built in the open</h4>
            <p>The code lives publicly on GitHub. Anyone can read it, suggest changes, or fork it for their own community.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ---------- FINAL CTA ---------- %>
  <section class="fd-cta-final">
    <div class="container text-center">
      <h2>Free. Forever. For everyone.</h2>
      <p>No card. No email tricks. Just open the chat and start asking.</p>
      <% if user_signed_in? %>
        <%= button_to "Start a new chat", chats_path, method: :post, class: "fd-btn fd-btn-primary fd-btn-lg", form: { class: "fd-btn-form" } %>
      <% else %>
        <%= link_to "Start chatting now", new_user_registration_path, class: "fd-btn fd-btn-primary fd-btn-lg" %>
      <% end %>
    </div>
  </section>

</div>
