<%= simple_form_for @stock do |f| %>
  <% if @stock.errors.any? %>
    <div class="fd-flash fd-flash-alert" style="position: static; transform: none; margin-bottom: 1.5rem; display: block;">
      <strong>Couldn't save:</strong>
      <ul class="mb-0">
        <% @stock.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.input :ticker, label: "Ticker symbol", placeholder: "e.g. NVDA, AAPL, TSLA" %>
  <%= f.input :company_name, label: "Company name", placeholder: "e.g. NVIDIA Corporation" %>
  <%= f.input :target_price, label: "Target price (USD)", placeholder: "e.g. 150.00" %>
  <%= f.input :notes, label: "Notes", as: :text, input_html: { rows: 4, placeholder: "Why are you watching this stock?" } %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "fd-btn fd-btn-primary" %>
    <%= link_to "Cancel", stocks_path, class: "fd-btn fd-btn-ghost" %>
  </div>
<% end %>
