<div class="fd-page" style="max-width: 720px;">
  <%= link_to stocks_path, class: "fd-back-link" do %>
    ← Back to watchlist
  <% end %>

  <div class="fd-page-head">
    <div>
      <h1><span class="fd-tkr-badge" style="font-size: 1.4rem; padding: 0.4rem 0.8rem;"><%= @stock.ticker.upcase %></span></h1>
      <% if @stock.company_name.present? %>
        <p style="margin-top: 0.5rem; margin-bottom: 0;"><%= @stock.company_name %></p>
      <% end %>
    </div>
    <div class="fd-page-head-actions">
      <%= link_to "Back to chat", chats_path, class: "fd-btn fd-btn-ghost" %>
      <%= link_to "Edit", edit_stock_path(@stock), class: "fd-btn fd-btn-ghost" %>
      <%= button_to "Remove", stock_path(@stock), method: :delete, class: "fd-btn fd-btn-danger", form: { class: "fd-btn-form", data: { turbo_confirm: "Remove #{@stock.ticker.upcase}?" } } %>
    </div>
  </div>

  <% if @stock.target_price.present? %>
    <div class="fd-card">
      <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #A0A0A0; margin-bottom: 0.4rem;">Target price</div>
      <div style="font-size: 2rem; font-weight: 700; color: #00FF88; font-family: 'JetBrains Mono', monospace;">
        <%= number_to_currency(@stock.target_price) %>
      </div>
    </div>
  <% end %>

  <% if @stock.notes.present? %>
    <div class="fd-card">
      <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: #A0A0A0; margin-bottom: 0.6rem;">Notes</div>
      <div style="line-height: 1.6;"><%= simple_format(@stock.notes) %></div>
    </div>
  <% end %>
</div>
