<div class="fd-page">
  <%= link_to chats_path, class: "fd-btn fd-btn-ghost fd-btn-sm fd-page-back" do %>
    <span aria-hidden="true">←</span> All chats
  <% end %>

  <div class="fd-page-head">
    <div class="fd-page-head-title">
      <span class="fd-eyebrow">
        <span class="fd-pulse-dot" aria-hidden="true"></span>
        Chat
      </span>
      <h1>
        <% if @chat.title.present? %>
          <%= @chat.title %>
        <% else %>
          Chat <span class="fd-accent">#<%= @chat.id %></span>
        <% end %>
      </h1>
    </div>
    <div class="fd-page-head-actions">
      <%= link_to "View watchlist", stocks_path, class: "fd-btn fd-btn-ghost" %>
      <%= link_to "+ Add a stock",  new_stock_path, class: "fd-btn fd-btn-primary" %>
    </div>
  </div>

  <div class="fd-chat-thread" id="messages">
    <% if @chat.messages.any? %>
      <% @chat.messages.each do |message| %>
        <% if message.role == "user" %>
          <div class="fd-chat-row fd-chat-row-user">
            <div class="fd-chat-bubble-msg">
              <%= simple_format(message.content) %>
            </div>
          </div>
        <% else %>
          <div class="fd-chat-row fd-chat-row-bot">
            <div>
              <div class="fd-chat-author">
                <span class="fd-chat-author-mark"><%= render "shared/brand_mark" %></span>
                Financial Dimes
              </div>
              <div class="fd-chat-bubble-msg">
                <%= simple_format(message.content) %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="fd-chat-empty">
        Type a message below to start the conversation.
      </div>
    <% end %>
  </div>

  <div class="fd-chat-input-wrap fd-form">
    <%= simple_form_for [@chat, @message] do |f| %>
      <%= f.input :content,
                  label: false,
                  placeholder: "Ask about a stock, or tell me one to add to your watchlist…",
                  required: true,
                  input_html: { rows: 3 } %>
      <div class="d-flex justify-content-end mt-2">
        <%= f.button :submit, "Send", class: "fd-btn fd-btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
