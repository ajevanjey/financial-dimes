<div class="container py-4" style="max-width: 800px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Chat #<%= @chat.id %></h1>
    <%= link_to "← Back", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div id="messages" class="mb-4">
    <% @chat.messages.each do |message| %>
      <% if message.role == "user" %>
        <div class="d-flex justify-content-end mb-3">
          <div class="bg-primary text-white p-3 rounded-3" style="max-width: 70%;">
            <%= simple_format(message.content) %>
          </div>
        </div>
      <% else %>
        <div class="d-flex justify-content-start mb-3">
          <div class="bg-white border p-3 rounded-3 shadow-sm" style="max-width: 70%;">
            <strong class="text-primary d-block mb-1">
              <i class="fas fa-robot"></i> Assistant
            </strong>
            <%= simple_format(message.content) %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <%= simple_form_for [@chat, @message] do |f| %>
        <%= f.input :content,
                    label: false,
                    placeholder: "Ask about a stock...",
                    required: true,
                    input_html: { rows: 3 } %>
        <div class="d-flex justify-content-end">
          <%= f.button :submit, "Send", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
