<div class="fd-page">
  <%= link_to root_path, class: "fd-btn fd-btn-ghost fd-btn-sm fd-page-back" do %>
    <span aria-hidden="true">←</span> Home
  <% end %>

  <div class="fd-page-head">
    <div class="fd-page-head-title">
      <span class="fd-eyebrow">
        <span class="fd-pulse-dot" aria-hidden="true"></span>
        Conversations
      </span>
      <h1>My <span class="fd-accent">chats</span></h1>
    </div>
    <div class="fd-page-head-actions">
      <%= link_to "View watchlist", stocks_path, class: "fd-btn fd-btn-ghost" %>
      <%= button_to "+ New chat", chats_path, method: :post, class: "fd-btn fd-btn-primary", form: { class: "fd-btn-form" } %>
    </div>
  </div>

  <% if @chats.any? %>
    <% @chats.each do |chat| %>
      <%= link_to chat_path(chat), class: "fd-card-link" do %>
        <div class="fd-card">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
              <h4 class="mb-1">
                <% if chat.title.present? %>
                  <%= chat.title %>
                <% else %>
                  Chat #<%= chat.id %>
                <% end %>
              </h4>
              <p class="mb-0" style="font-size: 0.85rem;">
                <%= chat.messages.count %> message<%= "s" if chat.messages.count != 1 %>
                <span style="opacity: 0.5;"> · </span>
                <%= chat.created_at.strftime("%b %d, %Y") %>
              </p>
            </div>
            <div onclick="event.preventDefault(); event.stopPropagation();">
              <%= button_to "Delete", chat_path(chat), method: :delete, class: "fd-btn fd-btn-danger fd-btn-sm", form: { class: "fd-btn-form", data: { turbo_confirm: "Delete this chat?" } } %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="fd-empty-state">
      <p>You don't have any chats yet.</p>
      <%= button_to "Start your first chat", chats_path, method: :post, class: "fd-btn fd-btn-primary fd-btn-lg", form: { class: "fd-btn-form" } %>
    </div>
  <% end %>
</div>
