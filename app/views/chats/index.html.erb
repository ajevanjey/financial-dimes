<div class="container-lg py-3 py-md-5">
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-3">
    <h1 class="mb-0">My chats</h1>
    <%= button_to "+ New chat", chats_path, method: :post, class: "btn btn-primary btn-lg w-100 w-sm-auto" %>
  </div>

  <% if @chats.any? %>
    <div class="list-group">
      <% @chats.each do |chat| %>
        <div class="list-group-item py-3">
          <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
            <%= link_to chat_path(chat), class: "text-decoration-none text-dark flex-grow-1" do %>
              <h5 class="mb-1">
                <% if chat.title.present? %>
                  <%= chat.title %>
                <% else %>
                  Chat #<%= chat.id %>
                <% end %>
              </h5>
              <small class="text-muted">
                <i class="fas fa-comment-dots me-1"></i>
                <%= chat.messages.count %> message<%= "s" if chat.messages.count != 1 %>
              </small>
            <% end %>
            <div class="d-flex align-items-center gap-2">
              <small class="text-muted text-nowrap">
                <i class="far fa-clock me-1"></i>
                <%= chat.created_at.strftime("%b %d, %Y") %>
              </small>
              <%= button_to chat_path(chat),
                            method: :delete,
                            class: "btn btn-outline-danger btn-sm",
                            form: { data: { turbo_confirm: "Supprimer ce chat?" } } do %>
                <i class="fas fa-trash"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info text-center py-5">
      <i class="fas fa-comments fa-2x mb-3 d-block"></i>
      <p class="mb-3">You don't have any chats yet.</p>
      <%= button_to "Start your first chat", chats_path, method: :post, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
