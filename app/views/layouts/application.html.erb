<!DOCTYPE html>
<html>
  <head>
    <title>Financial Dimes — Free, non-profit stock chat</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="theme-color" content="#00FF88">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Favicons / app icons — all use the same dime brand mark %>
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/icon.svg">
    <link rel="mask-icon" href="/icon.svg" color="#00FF88">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="fd-body">
    <%= render "shared/navbar" %>

    <% if notice.present? %>
      <div class="fd-flash fd-flash-notice"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="fd-flash fd-flash-alert"><%= alert %></div>
    <% end %>

    <main class="fd-main">
      <%= yield %>
    </main>
  </body>
</html>
